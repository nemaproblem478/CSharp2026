<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ProductManager.Pages"
             xmlns:models="clr-namespace:ProductManager.DTOModels.Warehouse;assembly=ProductManager.DTOModels"
             xmlns:vms="clr-namespace:ProductManager.Viewmodels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ProductManager.Pages.WarehousesPage"
             x:DataType="vms:WarehousesViewModel"
             x:Name="RootPage"
             Title="Warehouses" IsEnabled="{Binding IsNotBusy}">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
        EventName="Appearing"
        Command="{Binding BindingContext.RefreshDataCommand, Source={x:Reference RootPage}}"/>
    </ContentPage.Behaviors>
    <Grid RowDefinitions="Auto, 5*, Auto">
        <Border Grid.Row="0"
        StrokeThickness="0">
            <Grid ColumnDefinitions="*, *">
                <SearchBar Grid.Column="0"
                    Margin="5"
                    Text="{Binding SearchQuery}"
                    Placeholder="Enter Warehouse Name..."
                    CancelButtonColor="BlueViolet"/>

                <HorizontalStackLayout Grid.Column="1" Margin="5" Spacing="10" VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="Sort By:"  TextColor="White"
                           VerticalOptions="Center" HorizontalOptions="Center"/>
                    <Picker ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption}"
                            VerticalOptions="Center" HorizontalOptions="Center"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Path=VisibleWarehouses}"
            Margin="10"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate
                    x:DataType="models:WarehouseListDTO">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems
                                Mode="Reveal">
                                <SwipeItem
                                    Text="Delete"
                                    BackgroundColor="Red"
                                    Command="{Binding DeleteWarehouseCommand, Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}}" 
                                    CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <SwipeView.LeftItems>
                            <SwipeItems
                                Mode="Reveal">
                                <SwipeItem                                    
                                    Text="Edit"
                                    BackgroundColor="Blue"
                                    Command="{Binding EditWarehouseCommand, Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}}"
                                    CommandParameter="{Binding Id}"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        <Border
                            Stroke="BlueViolet"
                            Padding="10"
                            Margin="0,10">
                            
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                Command="{Binding LoadWarehouseCommand, Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}}"
                                CommandParameter="{Binding Id}"/>
                            </Border.GestureRecognizers>
                            <FlyoutBase.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Edit" 
                                        Command="{Binding EditWarehouseCommand, Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}}"
                                        CommandParameter="{Binding Id}"/>       
                                    <MenuFlyoutItem Text="Delete" 
                                        Command="{Binding DeleteWarehouseCommand, Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}}"
                                        CommandParameter="{Binding .}"/>
                                </MenuFlyout>
                            </FlyoutBase.ContextFlyout>
                            <VerticalStackLayout>
                                <Label
                                    Style="{StaticResource SubHeadline}"
                                    Text="{Binding Name}"/>
                                <Label
                                    Text="{Binding TotalCost, StringFormat='Total: ${0}'}"
                                    HorizontalOptions="Center"
                                    />
                            </VerticalStackLayout>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Border
            Grid.Row="2"
            Padding="10"
            BackgroundColor="BlueViolet"
            StrokeThickness="5"
            Stroke="BlueViolet">
            <Border.GestureRecognizers>
                <TapGestureRecognizer
                    Command="{Binding CreateClickedCommand}"/>
            </Border.GestureRecognizers>
            <Label
                Text="Add Warehouse"
                TextColor="White"
                Style="{StaticResource SubHeadline}"
            />
        </Border>
        <BoxView
            IsVisible="{Binding IsBusy}"
            BackgroundColor="Gray"
            Opacity="0.2"
            InputTransparent="False"/>
        <ActivityIndicator
            Color="BlueViolet"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>
    </Grid>
</ContentPage>