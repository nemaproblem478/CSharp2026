<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ProductManager.Pages"
             xmlns:models="clr-namespace:ProductManager.DTOModels.Warehouse;assembly=ProductManager.DTOModels"
             xmlns:vms="clr-namespace:ProductManager.Viewmodels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ProductManager.Pages.WarehousesPage"
             x:DataType="vms:WarehousesViewModel"
             x:Name="Page"
             Title="Warehouses">
    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding BindingContext.LoadDataCommand, Source={x:Reference Page}}" />
    </ContentPage.Behaviors>
    <CollectionView
        x:Name="warehouseCollectionView"
        ItemsSource="{Binding Path=Warehouses}"
        Margin="10"
        SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:WarehouseListDTO">
                <Border
                    Stroke="BlueViolet"
                    Padding="10"
                    Margin="0,10">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer
                        Command="{Binding Source={RelativeSource AncestorType={x:Type vms:WarehousesViewModel}}, Path=LoadWarehouseCommand}"
                        CommandParameter="{Binding Id}"/>
                </Border.GestureRecognizers>
                <VerticalStackLayout>
                    <Label
                        Style="{StaticResource SubHeadline}"
                        Text="{Binding Name}"/>
                    <Label
                        Text="{Binding TotalCost, StringFormat='Total: ${0}'}"
                        HorizontalOptions="Center"
                        />
                </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>