<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:ProductManager.Pages"
             xmlns:models="clr-namespace:ProductManager.UIModels;assembly=ProductManager.UIModels"
             x:Class="ProductManager.Pages.WarehousesPage"
             x:DataType="pages:WarehousesPage"
             Title="Warehouses">
    <CollectionView
        x:Name="warehouseCollectionView"
        ItemsSource="{Binding Warehouses}"
        Margin="10"
        SelectionMode="Single"
        SelectionChanged="WarehouseSelected">
        <CollectionView.ItemTemplate>
            <DataTemplate
                x:DataType="models:WarehouseUIModel">
                <Border
                    Stroke="BlueViolet"
                    Padding="10"
                    Margin="0,10">
                    <VerticalStackLayout>
                        <Label
                            Style="{StaticResource SubHeadline}"
                            Text="{Binding Name}"/>
                        <Label
                            Text="{Binding TotalCost, StringFormat='Total: ${0}'}"
                            HorizontalOptions="Center"
                            />
                        <Label 
                            Text="{Binding Location, Converter={StaticResource EnumToDisplayName}, StringFormat='Location: {0}'}"
                            HorizontalOptions="Center"
                            />
                    </VerticalStackLayout>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>