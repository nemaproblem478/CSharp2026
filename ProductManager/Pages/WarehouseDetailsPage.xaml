<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:ProductManager.UIModels;assembly=ProductManager.UIModels"
             x:Class="ProductManager.Pages.WarehouseDetailsPage"
             x:DataType="models:WarehouseUIModel"
             Title="Warehouse Details">
    <Grid RowDefinitions="Auto,5*,Auto">
        <Border 
            Grid.Row="0"
            Padding="10" 
            Margin="0,0"
            StrokeThickness="5"
            Stroke="BlueViolet"
            BackgroundColor="BlueViolet">
            <VerticalStackLayout>
                <Label
                    Style="{StaticResource SubHeadline}"
                    TextColor="White">
                    <Label.Text>
                        <MultiBinding
                            StringFormat="{}{0} (Total: ${1})">
                            <Binding Path="Name"></Binding>
                            <Binding Path="TotalCost"></Binding>
                        </MultiBinding>
                    </Label.Text>
                </Label>
                <Label 
                    Text="{Binding Location, Converter={StaticResource EnumToDisplayName}}"
                    HorizontalOptions="Center"
                    TextColor="White"/>
            </VerticalStackLayout>
        </Border>
        <Border
            Grid.Row="1"
            Padding="0"
            Margin="0,0">
            <CollectionView
                ItemsSource="{Binding Products}"
                SelectionMode="Single"
                SelectionChanged="ProductSelected"
                >
                <CollectionView.ItemTemplate>
                    <DataTemplate
                        x:DataType="models:ProductUIModel">
                        <Border
                            Padding="10"
                            >
                            <VerticalStackLayout>
                                <Label
                                    Style="{StaticResource SubHeadline}"
                                    Text="{Binding Name}"
                                    HorizontalOptions="Center"/>
                                <Label
                                    HorizontalOptions="Center">
                                    <Label.Text>
                                        <MultiBinding
                                            StringFormat="{}Category: {0}, Price: ${1}">
                                            <Binding Path="Category" Converter="{StaticResource EnumToDisplayName}"/>
                                            <Binding Path="Price"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
        <Button
            Grid.Row="2"
            BackgroundColor="BlueViolet"
            Clicked="CreateClicked"
            Text="Add Product"
            TextColor="White"
            FontSize="Title"
            CornerRadius="0"
            Margin="0">
        </Button>
    </Grid>
</ContentPage>