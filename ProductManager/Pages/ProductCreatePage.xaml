<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProductManager.Pages.ProductCreatePage"
             Title="Create a product"
             >
    <ScrollView>
        <VerticalStackLayout Padding="10">
            <Label Text="Name"
                    FontSize="20"
                    HorizontalOptions="Start"
            ></Label>
            <Entry Placeholder= "Name"
                    VerticalOptions="Start"
                    FontSize="20"
                    x:Name="eName"
            ></Entry>
            <Label Text="Description"
                    FontSize="20"
                    HorizontalOptions="Start"
            ></Label>
            <Entry Placeholder= "Description"
                    VerticalOptions="Start"
                    FontSize="20"
                    x:Name="eDescription"
            ></Entry>
        
            <Label Text="Category"
                    FontSize="20"
                    HorizontalOptions="Start"
            ></Label>
            <Picker Title="Pick a Category"
                    FontSize="20"
                    VerticalOptions="Start"
                    x:Name="pCategory"
                    ItemDisplayBinding="{Binding DisplayName}"
            ></Picker>
            <Label Text="Quantity"
                    FontSize="20"
                    HorizontalOptions="Start"
            ></Label>
            <Entry Placeholder= "Quantity"
                    VerticalOptions="Start"
                    FontSize="20"
                    Keyboard="Numeric"
                    x:Name="eQuantity"
                    TextChanged="OnQuantityEntryTextChanged"
            ></Entry>
            <Label Text="Price"
                    FontSize="20"
                    HorizontalOptions="Start"
            ></Label>
            <Entry Placeholder= "$"
                    VerticalOptions="Start"
                    FontSize="20"
                    Keyboard="Numeric"
                    x:Name="ePrice"
                    TextChanged="OnPriceEntryTextChanged"
            ></Entry>
            <Grid 
                ColumnDefinitions="*,*"
                ColumnSpacing="10"
                Padding="10">
                <Button
                    Grid.Column="0"
                    Text="Back"
                    Clicked="BackClicked">
                </Button>
                <Button
                    Grid.Column="1"
                    Text="Save"
                    Clicked="SaveClicked">
                </Button>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>